# -------------------------------------------------------
# Persönliche Daten – niemals einchecken
# -------------------------------------------------------

# Google Takeout Export (Fotos, Nachrichten, Bewertungen)
takeout/

# Lokale Datenbank (SQLite, Elasticsearch-Daten, Foto-Originals)
data/
!data/.gitkeep

# ChromaDB-Altdaten (deprecated — nur noch faces-Domain, Phase 2)
chroma_db/
chromadb_data/

# Sample-Liste (enthält keine Rohdaten, aber Dateinamen)
# sample/photo_sample.json darf eingecheckt werden – nur Metadaten

# Ältere Ergebnis-Dateien
results.json

# -------------------------------------------------------
# Credentials & Tokens
# -------------------------------------------------------
config/credentials.json
config/token.json

# Lokale Konfiguration (enthält ggf. API-Keys, URLs)
config.yaml
# config.yaml.example wird eingecheckt als Vorlage

